# Electron build environment
# Used via: vite build --mode electron
# Copy actual API URLs from .env and set VITE_ELECTRON=true

VITE_ELECTRON=true

# Point to your production backend
# Update these when your backend is deployed
VITE_API_URL=http://localhost:8000
VITE_ASSESSMENT_API_URL=http://localhost:8000

# Google OAuth Client ID (same as web)
VITE_GOOGLE_CLIENT_ID=

# Yjs collaboration server
VITE_YJS_URL=wss://diagrammatic-yjs-server.onrender.com
